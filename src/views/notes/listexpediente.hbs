<div class="col-md-7 mx-auto">
    <div class="card" style="font-style: italic;font-weight: bold;">
        <div class="card-header">
            <h3>Datos de Expediente</h3>
        </div>
        <div class="card-body">
            <form action="/notes/editexpediente/{{expediente._id}}?_method=PUT" method="POST">
                <input type="hidden" name="_method" value="PUT">
                <div class="form-group">
                    Nº Expediente:
                    <input type="text" name="numexpediente" class="form-control" placeholder="Sin Información"
                        value="{{expediente.numexpediente}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Estado:
                    <input type="text" name="estado" class="form-control" placeholder="Sin Información"
                        value="{{expediente.estado}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Iniciador (N y A):
                    <input name="iniciadornomyape" class="form-control"
                        value="{{expediente.iniciadornomyape}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Domicilio Iniciador:
                    <input type="text" name="domicilio" class="form-control" placeholder="Sin Información"
                        value="{{expediente.domicilio}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Adrema:
                    <input type="text" name="adremaexp" class="form-control" placeholder="Sin Información"
                        value="{{expediente.adremaexp}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Fiduciario, propietario o socio:
                    <input type="text" name="fiduciariopropsocio" class="form-control"
                        placeholder="Sin Información" value="{{expediente.fiduciariopropsocio}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Domicilio Fiduciario, propietario o socio:
                    <input type="text" name="direcfiduciariopropsocio" class="form-control"
                        placeholder="Sin Información" value="{{expediente.direcfiduciariopropsocio}}" style="color: #3d0ee7; font-weight: bold;" disabled></input>
                </div>
                <div class="form-group">
                    Email Fiduciario, propietario o socio:
                    <input type="text" name="correofiduciariopropsocio" class="form-control" placeholder="Sin Información"
                        value="{{expediente.correofiduciariopropsocio}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Director de obra o perito visor:
                    <input type="text" name="directorobraoperitovisor" class="form-control"
                        placeholder="Sin Información" value="{{expediente.directorobraoperitovisor}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Destino de Obra:
                    <input type="text" name="destinodeobra" class="form-control"
                        placeholder="Sin Información" value="{{expediente.destinodeobra}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                
                <div class="form-group">
                    Superficie de Terreno:
                    <input type="text" name="superficieterreno" class="form-control" placeholder="Sin Información"
                        value="{{expediente.superficieterreno}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Superficie a Construir:
                    <input type="text" name="superficieaconstruir" class="form-control" placeholder="Sin Información"
                        value="{{expediente.superficieaconstruir}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    superficie subsuelo, planta baja:
                    <textarea type="text" name="superficiesubsueloplantabaja" class="form-control" placeholder="Sin Información"
                        value="{{expediente.superficiesubsueloplantabaja}}" style="color: #3d0ee7; font-weight: bold;" disabled></textarea>
                </div>
                <div class="form-group">
                    Superficie primerpiso y más pisos:
                    <input type="text" name="superficieprimerpisoymaspisos" class="form-control" placeholder="Sin Información"
                        value="{{expediente.superficieprimerpisoymaspisos}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Observación:
                    <input type="text" name="observaciones" class="form-control" placeholder="Sin Información"
                        value="{{expediente.observaciones}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Permiso de obra o acta de infracción:
                    <input type="text" name="permisobraoactainfrac" class="form-control" placeholder="Sin Información"
                        value="{{expediente.permisobraoactainfrac}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                <div class="form-group">
                    Foto de Expediente:
                    <input type="file" name="fotoexpediente" class="form-control" placeholder="Sin Información"
                        value="{{expediente.fotoexpediente}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>
                {{!-- <img src="{{expediente.fotoinf}}" width="200" /> <br /><br /> --}}
                <div class="form-group">
                    Fecha de inicio de entrada:
                    <input type="date" name="fechainicioentrada" class="form-control" placeholder="Sin Información"
                        value="{{expediente.fechainicioentrada}}" style="color: #3d0ee7; font-weight: bold;" disabled>
                </div>

                <div class="form-group">
                    ID Usuario. Cargó Infracción
                    <input type="text" name="user" class="form-control" placeholder="Sin Información"
                        value="{{expediente.user}}" style="color: red;"  disabled>
                </div>
                <div class="form-group">
                    Fecha y Hora de Carga
                    <input type="datetime" name="dateinf" class="form-control" placeholder="Sin Información"
                    value="{{expediente.dateexp}}" style="color: red;" disabled>
                </div>

                <div class="form-group">
                    <p style="color:brown; font-style:oblique; font-weight: bold;"><a href="/expedientes"><i class="fas fa-list" style='font-size:24px;color:blue'></i></a> Volver</p>
                </div>
            </form>
        </div>
    </div>
</div>